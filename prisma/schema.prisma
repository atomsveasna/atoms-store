// Atoms Store — Database Schema
// Stack: PostgreSQL via Supabase + Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Products ──────────────────────────────────────────────────

model Product {
  id               String        @id @default(cuid())
  slug             String        @unique
  name             String
  tagline          String
  description      String
  longDescription  String?
  category         String
  status           String        @default("in_stock")
  price            Float
  currency         String        @default("USD")
  sku              String        @unique
  features         Json          // string[]
  specs            Json          // ProductSpec[]
  packageContents  Json          // string[]
  downloads        Json          // ProductDownload[]
  faqs             Json          // ProductFAQ[]
  relatedSlugs     Json          // string[]
  worksWithPlatforms Json        // string[]
  docSlug          String?
  firmwareVersion  String?
  revisionHistory  Json?         // { version, date, notes }[]
  isNew            Boolean       @default(false)
  isFeatured       Boolean       @default(false)
  images           ProductImage[]
  orderItems       OrderItem[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([category])
  @@index([status])
  @@index([isFeatured])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  src       String
  alt       String
  type      String  // render | photo | diagram
  order     Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// ── Orders ────────────────────────────────────────────────────

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  customerName    String
  customerEmail   String
  customerPhone   String
  shippingAddress Json        // ShippingAddress
  subtotal        Float
  shippingFee     Float       @default(0)
  total           Float
  currency        String      @default("USD")
  paymentMethod   String      // aba_transfer | cash_on_delivery
  paymentProofUrl String?
  status          String      @default("pending_payment")
  notes           String?
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([status])
  @@index([customerEmail])
  @@index([orderNumber])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  productName String
  sku         String
  quantity    Int
  unitPrice   Float
  totalPrice  Float
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}

// ── Support Requests ──────────────────────────────────────────

model SupportRequest {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  orderId     String?
  productSlug String?
  category    String
  subject     String
  message     String
  status      String   @default("open") // open | in_progress | resolved | closed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([email])
}

// ── Product Registration ──────────────────────────────────────

model ProductRegistration {
  id              String   @id @default(cuid())
  customerName    String
  customerEmail   String
  productSlug     String
  serialNumber    String?
  purchaseDate    DateTime?
  purchaseOrderId String?
  notes           String?
  createdAt       DateTime @default(now())

  @@index([customerEmail])
  @@index([productSlug])
}
