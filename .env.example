# ── Database ──────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/atoms_store"

# ── Supabase (if using Supabase) ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── Email (Resend) ────────────────────────────────────────────
RESEND_API_KEY="re_your_key"
EMAIL_FROM="orders@atoms.store"
EMAIL_SUPPORT="support@atoms.store"

# ── Notifications ─────────────────────────────────────────────
# Telegram bot for order notifications (Phase 0 ops)
TELEGRAM_BOT_TOKEN="your-bot-token"
TELEGRAM_CHAT_ID="your-chat-id"

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://atoms.store"
NEXT_PUBLIC_STORE_NAME="Atoms Store"
NEXT_PUBLIC_STORE_EMAIL="hello@atoms.store"
NEXT_PUBLIC_STORE_PHONE="+855 XX XXX XXXX"

# ── ABA Payment ───────────────────────────────────────────────
NEXT_PUBLIC_ABA_ACCOUNT_NAME="Atoms Co., Ltd."
NEXT_PUBLIC_ABA_ACCOUNT_NUMBER="000XXXXXXXXX"
NEXT_PUBLIC_ABA_BANK="ABA Bank"
